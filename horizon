#!/bin/bash

osascript <<'EOF'

set tab1Dir to "/Users/ludell/Documents/Avinor/frontend"
set tab2Dir to "/Users/ludell/Documents/Avinor/selfservice-frontend"
set tab3Dir to "/Users/ludell/Documents/Avinor/selfservice-frontend"
set tab4Dir to "/Users/ludell/Documents/Avinor/backend"
set tab5Dir to "/Users/ludell/Documents/Avinor/backend"
set tab6Dir to "/Users/ludell/Documents/Avinor/auth-service"
set tab7Dir to "/Users/ludell/Documents/Avinor/auth-service"
set tab8Dir to "/Users/ludell/Documents/Avinor/avai/docker/app"
set tab9Dir to "/Users/ludell/Documents/Avinor"

tell application "Ghostty"
    activate

    -- Tab 1
    set cfg1 to new surface configuration
    set initial working directory of cfg1 to tab1Dir
    set win to new window with configuration cfg1
    delay 0.3
    set term to focused terminal of selected tab of win
    perform action "set_tab_title:frontend" on term

    -- Tab 2
    set cfg2 to new surface configuration
    set initial working directory of cfg2 to tab2Dir
    set t2 to new tab in win with configuration cfg2
    delay 0.3
    perform action "set_tab_title:selfservice-frontend" on focused terminal of t2

    -- Tab 3
    set cfg3 to new surface configuration
    set initial working directory of cfg3 to tab3Dir
    set t3 to new tab in win with configuration cfg3
    delay 0.3
    perform action "set_tab_title:selfservice-backend" on focused terminal of t3

    -- Tab 4
    set cfg4 to new surface configuration
    set initial working directory of cfg4 to tab4Dir
    set t4 to new tab in win with configuration cfg4
    delay 0.3
    perform action "set_tab_title:backend" on focused terminal of t4

    -- Tab 5
    set cfg5 to new surface configuration
    set initial working directory of cfg5 to tab5Dir
    set t5 to new tab in win with configuration cfg5
    delay 0.3
    perform action "set_tab_title:backend-2" on focused terminal of t5

    -- Tab 6
    set cfg6 to new surface configuration
    set initial working directory of cfg6 to tab6Dir
    set t6 to new tab in win with configuration cfg6
    delay 0.3
    perform action "set_tab_title:auth-service" on focused terminal of t6

    -- Tab 7
    set cfg7 to new surface configuration
    set initial working directory of cfg7 to tab7Dir
    set t7 to new tab in win with configuration cfg7
    delay 0.3
    perform action "set_tab_title:auth-service-2" on focused terminal of t7

    -- Tab 8
    set cfg8 to new surface configuration
    set initial working directory of cfg8 to tab8Dir
    set t8 to new tab in win with configuration cfg8
    delay 0.3
    perform action "set_tab_title:docker" on focused terminal of t8

    -- Tab 9
    set cfg9 to new surface configuration
    set initial working directory of cfg9 to tab9Dir
    set t9 to new tab in win with configuration cfg9
    delay 0.3
    perform action "set_tab_title:avinor" on focused terminal of t9

    -- Focus the first tab
    select tab (tab 1 of win)
end tell
EOF